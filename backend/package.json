    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/express": "^4.17.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "@types/cors": "^2.8.13",
    "typescript": "^5",
    "ts-node": "^10.9.1"
